<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- Dongle settings -->
    <add key="DongleRequired" value="true" />

    <!-- Controller connection settings -->
    <add key="ControllerComPort" value="COM3" />
    <add key="ControllerBaudRate" value="9600" />
    <add key="ControllerReadTimeoutSeconds" value="10" />

    <!-- Fault analysis thresholds -->
    <add key="FaultThreshold" value="3" />
    <add key="HighSeverityThreshold" value="2" />
    <add key="DefaultDaysBack" value="30" />

    <!-- Database connection (fake - not real credentials) -->
    <add key="FaultDbConnectionString" value="Server=localhost;Database=KstLceFaults;Integrated Security=true;" />
  </appSettings>
</configuration>
